# Terminalog Configuration File
# 
# This is an example configuration file.
# Copy this file to config.toml and customize it.

[blog]
# Path to your Git repository containing blog content.
# This directory must be a Git repository (initialized with git init).
# All Markdown files (.md) in this directory will be treated as blog articles.
content_dir = "./content"

# Owner name displayed in the navbar path, for example ~/alice
owner = "lordcasser"

[server]
# Server host address (default: 0.0.0.0 for all interfaces)
host = "0.0.0.0"

# Server port (default: 8080 for HTTP, 443 for HTTPS)
port = 8080

# Enable debug mode for local frontend/backend split development
debug = false

# Enable HTTPS/TLS (default: false)
# When enabled, the server serves HTTPS and can auto-redirect HTTP to HTTPS.
tls_enabled = false

# TLS certificate file path (PEM format).
# When tls_enabled is true and not set, auto-detected from default paths:
#   - resources/https.crt, resources/cert.pem, cert.pem
# cert_file = "/etc/terminalog/cert.pem"

# TLS private key file path (PEM format).
# When tls_enabled is true and not set, auto-detected from default paths:
#   - resources/https.key, resources/key.pem, key.pem
# key_file = "/etc/terminalog/key.pem"

# HTTP→HTTPS redirect server address.
# When tls_enabled on standard port 443, defaults to ":80".
# For non-standard HTTPS ports, no redirect by default (opt-in).
# Set to "-" to explicitly disable redirect.
# http_redirect_addr = ":80"

# Auto-generate self-signed certificate for development.
# When true and tls_enabled is true but no cert files are found,
# a self-signed certificate will be auto-generated.
# WARNING: For development/testing ONLY! Never use in production.
# auto_cert = false

[auth]
# Users for Git push authentication.
# When you push new content to the blog, you need to authenticate.
# 
# Password can be either:
# 1. Plain text (will be hashed on first run) - easier for initial setup
# 2. bcrypt hash (starts with $2a$, $2b$, or $2y$) - more secure
#
# On first run, if no users are configured, a default admin user
# will be generated with a random password, which will be printed
# to the console. You should change this password in config.toml.

users = [
  # Example user with plain text password (will be hashed on startup)
  # { username = "admin", password = "your-password" },
  
  # Example user with bcrypt hashed password
  # { username = "admin", password = "$2a$10$..." },
]

# Example configuration:
# 
# [blog]
# content_dir = "/home/user/my-blog"
# 
# [server]
# host = "127.0.0.1"
# port = 3000
# 
# [auth]
# users = [
#   { username = "writer", password = "my-secure-password" },
# ]
